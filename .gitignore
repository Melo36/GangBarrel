# Ignore Unity directories within GangBarrel
/GangBarrel/[Ll]ibrary/
/GangBarrel/[Tt]emp/
/GangBarrel/[Oo]bj/
/GangBarrel/[Bb]uild/
/GangBarrel/[Bb]uilds/
/GangBarrel/[Ll]ogs/
/GangBarrel/[Uu]ser[Ss]ettings/

# MemoryCaptures and Recordings
/GangBarrel/[Mm]emoryCaptures/
/GangBarrel/[Rr]ecordings/

# Asset Store Tools plugin
# /GangBarrel/[Aa]ssets/AssetStoreTools*

# Jetbrains Rider plugin
/GangBarrel/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio, Gradle, and autogenerated files
.vs/
.gradle/
/GangBarrel/ExportedObj/
/GangBarrel/.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash report files and builds
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables and Android Assets
/GangBarrel/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/GangBarrel/[Aa]ssets/[Ss]treamingAssets/aa.meta
/GangBarrel/[Aa]ssets/[Ss]treamingAssets/aa/*
